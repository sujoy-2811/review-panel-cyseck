generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  employee
}

enum ReviewStatus {
  pending
  in_progress
  completed
}

enum AssignmentStatus {
  pending
  submitted
}

model Employee {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  department   String?
  role         Role      @default(employee)
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at") // soft delete

  reviewsAsReviewee PerformanceReview[] @relation("Reviewee")
  reviewsCreated    PerformanceReview[] @relation("CreatedBy")
  assignments       ReviewAssignment[]  @relation("Participant")

  @@map("employees")
}

model PerformanceReview {
  id          String       @id @default(uuid())
  employeeId  String       @map("employee_id")
  employee    Employee     @relation("Reviewee", fields: [employeeId], references: [id], onDelete: Cascade)
  createdById String       @map("created_by")
  createdBy   Employee     @relation("CreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  title       String
  period      String       // e.g. "Q1 2026"
  status      ReviewStatus @default(pending)
  dueDate     DateTime?    @map("due_date")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  assignments ReviewAssignment[]

  @@map("performance_reviews")
}


model ReviewAssignment {
  id            String            @id @default(uuid())
  reviewId      String            @map("review_id")
  review        PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  participantId String            @map("participant_id")
  participant   Employee          @relation("Participant", fields: [participantId], references: [id], onDelete: Cascade)
  status        AssignmentStatus  @default(pending)
  comment       String?
  rating        Int?              // 1-5
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@unique([reviewId, participantId])
  @@map("review_assignments")
}
