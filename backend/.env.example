# For Docker: use container name "review_panel_db" as host instead of "localhost"
DATABASE_URL="postgresql://<username>:<password>@localhost:5432/review_panel"


PORT=3000
JWT_SECRET="put-any-secret-code"

# Required: website URL used in password reset emails
FRONTEND_URL="http://localhost:5173"

# API key from Resend (for sending emails)
RESEND_API_KEY="enter_resend_api"

# Must match a verified domain in your Resend account
RESEND_FROM_EMAIL=noreply@mail.abcd.in

# PostgreSQL credentials — used by docker-compose
POSTGRES_USER=review_user
POSTGRES_PASSWORD=review_pass
POSTGRES_DB=review_panel
